{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/health", "destination": "/api/health" },
    { "source": "/api/state", "destination": "/api/state" },
    { "source": "/api/tasks", "destination": "/api/tasks" },
    { "source": "/api/tasks/:id/claim", "destination": "/api/tasks-claim?id=:id" },
    { "source": "/api/tasks/:id/updates", "destination": "/api/tasks-updates?id=:id" },
    { "source": "/api/tasks/:id", "destination": "/api/tasks?id=:id" },
    { "source": "/api/agents/register", "destination": "/api/agents-register" },
    { "source": "/api/agents/heartbeat", "destination": "/api/agents-heartbeat" },
    { "source": "/api/calendar", "destination": "/api/calendar" },
    { "source": "/api/calendar/:id", "destination": "/api/calendar?id=:id" },
    { "source": "/api/memories", "destination": "/api/memories" },
    { "source": "/api/memories/:id", "destination": "/api/memories?id=:id" },
    { "source": "/api/templates", "destination": "/api/templates" },
    { "source": "/api/docs", "destination": "/api/docs" },
    { "source": "/api/docs/:id", "destination": "/api/docs?id=:id" },
    { "source": "/api/scraper", "destination": "/api/scraper" },
    { "source": "/api/scraper/:id", "destination": "/api/scraper?id=:id" }
  ]
}
